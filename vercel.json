{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install && cd ../backend && npm install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/test-auth",
      "destination": "/api/test-auth.js"
    },
    {
      "source": "/test-simple",
      "destination": "/api/test-simple.js"
    },
    {
      "source": "/((?!api|uploads|test-auth|test-simple).*)",
      "destination": "/frontend/$1"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    },
    "api/test-auth.js": {
      "maxDuration": 15
    },
    "api/test-simple.js": {
      "maxDuration": 10
    }
  }
}
